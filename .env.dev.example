# Local-dev env template — see docs/dev-setup.md for the full setup walkthrough.
#
# Copy this file three times in the repo root, one per role:
#   .env.dev.treasury
#   .env.dev.member-a
#   .env.dev.member-b
#
# Then edit each copy with the actual values for that role (the LND gRPC port
# Polar exposes for that node, the path to that node's data directory inside
# ~/.polar/networks/<id>/volumes/lnd/<name>/, and the same TREASURY_PUBKEY in
# all three).
#
# All three .env.dev.* files (other than this example) are gitignored.

# gRPC address of the LND node this instance talks to.
# Polar exposes its first three LND nodes on 10001/10002/10003 by default —
# confirm in each Polar node's Connect tab.
LND_GRPC_HOST=127.0.0.1:10001

# Path on your machine to this LND node's data directory.
# Find your network id with `ls ~/.polar/networks/` and confirm the node name
# (treasury / farmer / merchant after renaming in Polar).
LND_DIR=/home/<you>/.polar/networks/<id>/volumes/lnd/<node-name>

# Network the local LND nodes are on. Polar uses regtest by default;
# this also determines the macaroon path the API reads.
BITCOIN_NETWORK=regtest

# Compressed pubkey (66-char hex) of your local treasury Polar LND node.
# Capture from the treasury node's Connect tab in Polar.
# The SAME value goes in all three .env.dev.* files — that's how the
# treasury instance recognizes itself and members detect their hub.
TREASURY_PUBKEY=

# Port for this API instance. Use 3101 for treasury, 3102 for member-a,
# 3103 for member-b so they don't collide.
PORT=3101
