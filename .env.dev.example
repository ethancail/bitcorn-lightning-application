# Local-dev env template — see docs/dev-setup.md for the full setup walkthrough.
#
# Copy this file three times in the repo root, one per role:
#   .env.dev.treasury
#   .env.dev.member-a
#   .env.dev.member-b
#
# Then edit each copy with the actual values for that role (the LND gRPC port
# Polar exposes for that node, the path to that node's data directory inside
# ~/.polar/networks/<id>/volumes/lnd/<name>/, and the same TREASURY_PUBKEY in
# all three).
#
# All three .env.dev.* files (other than this example) are gitignored.

# gRPC address of the LND node this instance talks to.
# Polar exposes its first three LND nodes on 10001/10002/10003 by default —
# confirm in each Polar node's Connect tab.
LND_GRPC_HOST=127.0.0.1:10001

# Path on your machine to this LND node's data directory.
# Find your network id with `ls ~/.polar/networks/` and confirm the node name
# (treasury / farmer / merchant after renaming in Polar).
LND_DIR=/home/<you>/.polar/networks/<id>/volumes/lnd/<node-name>

# Network the local LND nodes are on. Polar uses regtest by default;
# this also determines the macaroon path the API reads.
BITCOIN_NETWORK=regtest

# Compressed pubkey (66-char hex) of your local treasury Polar LND node.
# Capture from the treasury node's Connect tab in Polar.
# The SAME value goes in all three .env.dev.* files — that's how the
# treasury instance recognizes itself and members detect their hub.
TREASURY_PUBKEY=

# Subscription rail — entitlement-token refresh target.
# As of v1.14.1, this env var is OPTIONAL on member nodes. If unset,
# members discover the treasury API URL via the Worker's /treasury-info
# endpoint (the treasury operator publishes it once via
# `wrangler secret put TREASURY_API_URL`). Set this only when:
#   - Local-dev: TREASURY_API_URL=http://localhost:3101 for member-A/B
#   - Operator override: pointing at a non-standard treasury URL
# Treasury nodes leave this unset — the /token endpoint's self-mint
# carve-out hits localhost.
TREASURY_API_URL=

# Port for this API instance. Use 3101 for treasury, 3102 for member-a,
# 3103 for member-b so they don't collide.
PORT=3101

# Path on your machine where this instance's SQLite database lives.
# Production on Umbrel uses /data/db (provided by a volume mount); locally
# you need a writable path. Use a per-role subdirectory so the three
# instances don't share state. The directory is auto-created on startup
# (mode 0o700) — no need to mkdir it yourself.
DB_DIR=/home/<you>/.bitcorn-dev/<role>/db

# Path where this instance's master key (used for autobuy credential
# encryption + JWT signing) lives. Production on Umbrel uses /data/secrets
# via volume mount; locally use a per-role writable path. Created lazily
# on first encrypt/decrypt call (mode 0o700 dir, 0o600 file).
SECRETS_DIR=/home/<you>/.bitcorn-dev/<role>/secrets

# ─────────────────────────────────────────────────────────────────────
# Optional: Loop Fidelity Layer
# ─────────────────────────────────────────────────────────────────────
# Only set the variables below if your work touches the Loop subsystem
# (real Loop In / Loop Out swaps in regtest). The base local-dev setup
# above is sufficient for everything else. See docs/dev-setup.md
# § Optional: Loop Fidelity Layer for the full walkthrough.

# gRPC endpoint of the locally-running loopserver process. Member loopd
# instances connect to this instead of Lightning Labs' production server.
# Default port matches loopserver's own default; override if it collides.
LOOPSERVER_HOST=localhost:11009

# External-Peer-1 LND identity — the fourth Polar node that anchors
# loopserver. Capture pubkey + gRPC port from External-Peer-1's Connect
# tab in Polar after adding the node.
EXTERNAL_PEER_PUBKEY=
EXTERNAL_PEER_LND_GRPC=127.0.0.1:0
EXTERNAL_PEER_LND_DIR=/home/<you>/.polar/networks/<id>/volumes/lnd/External-Peer-1

# Per-role loopd data directory. Each member's loopd needs its own
# state (macaroons, swap history, etc). Created at the path on first
# loopd startup. Production never sets these — Loop runs only on
# Umbrel's litd-embedded path there.
LOOPD_DIR_TREASURY=/home/<you>/.bitcorn-dev/treasury/loopd
LOOPD_DIR_MEMBER_A=/home/<you>/.bitcorn-dev/member-a/loopd
LOOPD_DIR_MEMBER_B=/home/<you>/.bitcorn-dev/member-b/loopd

# Per-role loopd RPC ports. The Bitcorn API on each role connects to
# its corresponding loopd at this port. Pick non-colliding numbers;
# the defaults below match dev:kill's port list.
# These document the loopd's --rpclisten port. The actual env vars the
# API reads are LOOP_GRPC_HOST/PORT below; copy the matching port into
# each role's per-file overrides.
LOOPD_RPC_TREASURY=11010
LOOPD_RPC_MEMBER_A=11020
LOOPD_RPC_MEMBER_B=11030

# Per-role API → loopd connection. The Bitcorn API uses these to reach
# its corresponding loopd over gRPC. Set the PORT to match this role's
# LOOPD_RPC_* value above (treasury=11010, member-a=11020, member-b=11030).
# TLS_CERT_PATH and MACAROON_PATH point at files loopd auto-creates inside
# its --loopdir on first run. Both live under the regtest/ subdirectory
# (created from loopd's --network=regtest setting); the loopdir root only
# holds logs/ and macaroons.db.
LOOP_GRPC_HOST=127.0.0.1
LOOP_GRPC_PORT=11010
LOOP_TLS_CERT_PATH=/home/<you>/.bitcorn-dev/<role>/loopd/regtest/tls.cert
LOOP_MACAROON_PATH=/home/<you>/.bitcorn-dev/<role>/loopd/regtest/loop.macaroon

# Source pubkey for the Loop In route preflight. In production this defaults
# to Lightning Labs' Loop server pubkey. Locally, loopserver is anchored to
# External-Peer-1's LND, so the preflight must start at External-Peer-1's
# pubkey or it will fail with "route_unavailable" before reaching loopserver.
# Capture this value from External-Peer-1's Connect tab in Polar.
LOOP_SERVER_PUBKEYS=
