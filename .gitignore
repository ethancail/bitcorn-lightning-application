# Dependencies
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
*.tsbuildinfo

# Environment variables
.env
.env.local
.env.*.local
# Per-machine local-dev env files (see docs/dev-setup.md). The .example
# template is tracked; the real .env.dev.treasury / .env.dev.member-a /
# .env.dev.member-b live only on your machine.
.env.dev.*
!.env.dev.example

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*

# Data — runtime SQLite + WAL/SHM at any depth under data/.
# The original `data/*.sqlite` pattern didn't recurse, so
# `data/db/bitcorn.sqlite` (and -wal/-shm) silently slipped into the
# index. Recursive-glob form covers subdirs and the WAL/SHM siblings.
data/**/*.db
data/**/*.sqlite*

# Secrets
secrets/
*.key
*.pem

# Screenshots (Playwright/dev previews)
screenshots/
# Root-level scratch screenshots from ad-hoc dev sessions.
/*.png

# Pandoc-rendered scratch HTML at the repo root.
/*.html

# Local dev overrides (contain local pubkeys and paths)
docker-compose.override.yml
dev/lnd/

# Brainstorming session artifacts
.superpowers/

# Cloudflare wrangler local-dev secrets (gitignored — never commit)
cloudflare-worker/.dev.vars
# Wrangler's local-dev state cache (miniflare KV, etc.) — per-machine.
cloudflare-worker/.wrangler/

# Claude Code per-project state (agents, settings, session data).
.claude/

# Playwright-MCP per-project snapshot artifacts (page-*.yml dumps).
.playwright-mcp/
