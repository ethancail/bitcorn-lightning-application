# BitCorn Lightning — per-install operator secrets
#
# Copy this file to `.env` in the same directory and fill in values.
# `.env` is gitignored repo-wide — the actual secret never touches git.
# Docker Compose reads `.env` automatically on `docker compose up`.
#
# On Umbrel: this file lives at ~/umbrel/app-data/bitcorn-lightning-node/
# After editing .env, restart the app:
#   sudo umbreld client apps.restart.mutate --appId bitcorn-lightning-node

# ── Valuation manual-input submission (treasury node → Cloudflare Worker) ──
# Shared HMAC secret that signs POST /valuation/manual payloads. The same
# value must be set on the Worker via:
#   cd cloudflare-worker && npx wrangler secret put VALUATION_SUBMIT_HMAC
# Generate a fresh 32-byte hex secret with:
#   openssl rand -hex 32
# If left unset, POST /api/valuation/manual returns 503 valuation_worker_not_configured
# and the treasury web UI's "Save All" button reports a 503 toast.
VALUATION_SUBMIT_HMAC=

# Optional — URL of the Worker that exposes POST /valuation/manual.
# Defaults to the value of COINBASE_WORKER_URL already set in docker-compose.yml.
# Override only if you split the Onramp and Valuation Workers.
# VALUATION_WORKER_URL=https://bitcorn-onramp.example.workers.dev
