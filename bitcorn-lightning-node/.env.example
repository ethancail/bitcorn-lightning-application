# BitCorn Lightning — per-install operator secrets
#
# Copy this file to `.env` in the same directory and fill in values.
# `.env` is gitignored repo-wide — the actual secret never touches git.
# Docker Compose reads `.env` automatically on `docker compose up`.
#
# On Umbrel: this file lives at ~/umbrel/app-data/bitcorn-lightning-node/
# After editing .env, restart the app:
#   sudo umbreld client apps.restart.mutate --appId bitcorn-lightning-node

# ── Valuation manual-input submission (treasury node → Cloudflare Worker) ──
# Shared HMAC secret that signs POST /valuation/manual payloads. The same
# value must be set on the Worker via:
#   cd cloudflare-worker && npx wrangler secret put VALUATION_SUBMIT_HMAC
# Generate a fresh 32-byte hex secret with:
#   openssl rand -hex 32
# If left unset, POST /api/valuation/manual returns 503 valuation_worker_not_configured
# and the treasury web UI's "Save All" button reports a 503 toast.
VALUATION_SUBMIT_HMAC=

# Optional — URL of the Worker that exposes POST /valuation/manual.
# Defaults to the value of COINBASE_WORKER_URL already set in docker-compose.yml.
# Override only if you split the Onramp and Valuation Workers.
# VALUATION_WORKER_URL=https://bitcorn-onramp.example.workers.dev

# ── Cloudflare Tunnel (Phase 4 — named tunnel for cross-tailnet members) ──
# A persistent named Cloudflare Tunnel that exposes the API container at a
# stable hostname (e.g., https://treasury.<your-domain>). Required so members
# on different tailnets than the treasury can reach it; tailnet-private IPs
# do not work for cross-tailnet members (Stage 4.5 reachability gap).
#
# To activate Phase 4:
#   1. Create a tunnel in Cloudflare dashboard (Zero Trust → Networks →
#      Tunnels → Create a tunnel → Cloudflared → name "bitcorn-treasury").
#   2. Copy the TUNNEL_TOKEN from the tunnel install screen (long base64).
#      Paste below — NO surrounding quotes, NO trailing whitespace.
#   3. In the Cloudflare dashboard's "Public Hostname" tab for this tunnel,
#      route treasury.<your-domain> → http://bitcorn-lightning-node_api_1:3101
#      and let the dashboard create the CNAME record automatically.
#   4. Set COMPOSE_PROFILES=tunnel below to activate the cloudflared sidecar.
#   5. Update the Worker secret to point at the new URL:
#        cd cloudflare-worker
#        npx wrangler secret put TREASURY_API_URL    # paste https://treasury.<your-domain>
#        npx wrangler deploy
#
# Operators NOT on Phase 4 (no Cloudflare account, staying on Phase 1
# ephemeral, or tailnet-only deployment) leave both values unset and
# the cloudflared sidecar stays off.
#
# Full setup procedure: docs/operator-runbook.md (Cloudflare Tunnel section).
TUNNEL_TOKEN=

# Activates the cloudflared sidecar in docker-compose.yml. Set to `tunnel`
# only after TUNNEL_TOKEN is populated above. Leave unset for non-tunnel
# deployments — the cloudflared service will stay off.
COMPOSE_PROFILES=
